{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist-electron",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "types": ["node", "jest"]
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared-types/**/*.ts"
  ],
  "references": [
    { "path": "../shared" }
  ]
}
