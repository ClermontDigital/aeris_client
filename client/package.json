{
  "name": "aeris-client",
  "version": "2.2.2",
  "private": true,
  "description": "Aeris v2 — relay-native Electron client. Successor to archive/desktop-v1.",
  "homepage": "https://github.com/ClermontDigital/aeris_client",
  "author": {
    "name": "Clermont Digital",
    "email": "support@clermontdigital.com.au"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "ts-jest": "^29.2.0",
    "typescript": "~5.9.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@aeris/shared": "*",
    "electron-log": "^5.2.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "zustand": "^4.5.0"
  }
