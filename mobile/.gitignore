# Expo managed native directories. These are regenerated by `expo prebuild`, so
# the native projects themselves are not committed.
ios/
android/

# EXCEPTION: the Xcode Cloud post-clone hook MUST be committed so Apple's CI can
# find it (it runs BEFORE prebuild regenerates the rest of ios/). The negation
# below un-ignores only ios/ci_scripts/ -- everything else under ios/ stays
# ignored. Order matters: a negation must come after the broader ignore, and the
# parent dir cannot be excluded, hence the explicit `!ios/` then re-scope.
!ios/
ios/*
!ios/ci_scripts/
!ios/ci_scripts/**

# Expo cache
.expo/
