# Native projects. ios/ IS committed (scaffold + AERIS.xcscheme) so Xcode Cloud
# can resolve the scheme — matches beats / plot_mobile. ci_post_clone.sh still
# runs `expo prebuild --clean` to regenerate the native code at build time, so the
# committed ios/ is just a scaffold. ios/.gitignore (Expo-generated) keeps Pods/,
# build/, xcuserdata, *.xcworkspace and .xcode.env.local out of git.
# android/ stays CNG (Continuous Native Generation) — regenerated by prebuild.
android/

# Expo cache
.expo/
