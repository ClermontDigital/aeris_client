{
  "expo": {
    "name": "AERIS",
    "slug": "aeris",
    "version": "1.3.8",
    "orientation": "default",
    "icon": "./assets/images/app-icon.png",
    "scheme": "aeris",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#003049"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aeris.erp",
      "icon": "./assets/images/app-icon.png",
      "requireFullScreen": false,
      "infoPlist": {
        "CFBundleDisplayName": "AERIS",
        "UIStatusBarHidden": true,
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIRequiresPersistentWiFi": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSAllowsArbitraryLoadsInWebContent": true,
          "NSExceptionDomains": {
            "aeris.local": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        },
        "NSCameraUsageDescription": "AERIS uses the camera to scan product barcodes at the point of sale so you can add items to a transaction without typing.",
        "NSFaceIDUsageDescription": "AERIS uses Face ID to unlock the app between sessions so you don't have to re-enter your PIN every time you switch back.",
        "NSLocalNetworkUsageDescription": "AERIS connects to your on-premises AERIS server on the local network when Direct connection mode is enabled."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1", "0A2A.1", "3B52.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1", "85F4.1"]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#003049"
      },
      "package": "com.aeris.erp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "./plugins/withFollyCoroutinesFix",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "ccacheEnabled": true,
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "AERIS uses the camera to scan product barcodes at the point of sale so you can add items to a transaction without typing."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "AERIS uses Face ID to unlock the app between sessions so you don't have to re-enter your PIN every time you switch back."
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-sharing",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "d3ce5116-b28a-4fb8-bac6-6ea080d273df"
      }
    },
    "owner": "clermont-digital",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
