{
  "name": "aeris-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Aeris Client monorepo: shared contract layer, mobile (Expo), and client (Electron v2). Archive (desktop-v1) is excluded from workspaces and built only on-demand.",
  "workspaces": [
    "shared",
    "mobile",
    "client"
  ],
  "scripts": {
    "test:all": "npm test --workspaces --if-present",
    "typecheck": "tsc --build",
    "clean": "npm run clean --workspaces --if-present && rimraf node_modules"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "@tootallnate/once": "^2.0.1",
    "brace-expansion": "^2.0.2",
    "esbuild": "^0.25.0",
    "minimatch": "^3.1.3",
    "picomatch": "^2.3.2",
    "postcss": "^8.5.10",
    "tar": "^7.5.11",
    "vite": "^6.4.2",
    "ws": "^8.20.1"
  }
}
